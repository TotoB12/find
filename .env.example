DEBUG=0

# Bind the app to your Tailscale IP if OwnTracks should post directly to the Pi.
APP_BIND_IP=100.100.100.100
APP_PORT=8000

# Public viewer/admin URL. Leave blank only if a reverse proxy always forwards the final host.
PUBLIC_BASE=https://find.example.com

# Viewer label shown in the top-left HUD.
VIEWER_LABEL=Antonin Beliard

# Mapbox
MAPBOX_PUBLIC_TOKEN=replace-with-your-mapbox-public-token
MAPBOX_STYLE_URL=mapbox://styles/mapbox/light-v11

# Admin auth
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_TOKEN=
ADMIN_SESSION_SECRET=replace-with-a-random-secret
ADMIN_SESSION_TTL_SECONDS=43200

# OwnTracks HTTP auth
OT_USER=replace-with-owntracks-username
OT_PASS=replace-with-owntracks-password

# Restrict OwnTracks ingest to trusted networks such as Tailscale.
OWNTRACKS_ENFORCE_IP=1
OWNTRACKS_ALLOWED_CIDRS=100.64.0.0/10,127.0.0.1/32,::1/128

# Viewer session controls
VIEWER_TOKEN_TTL_SECONDS=600
DEVICE_COOKIE_MAX_AGE_SECONDS=31536000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token
